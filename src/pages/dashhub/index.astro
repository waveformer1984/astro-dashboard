---
import Layout from "../../layouts/Main.astro";
---

<Layout>
  <main class="page">
    <div class="section">
      <h1 class="heading-primary">Hydi DashHub</h1>
      <p class="typography-primary">Central orchestration for apps and automations.</p>
      <div class="list-actions">
        <a class="button-primary" href="/funding">Funding Finder</a>
        <a class="button-secondary" href="/setup">Setup & Activation</a>
        <a class="button-secondary" href="/roadmap">Visual Roadmap</a>
      </div>
    </div>

    <hr class="divider" />

    <div class="section">
      <h2 class="heading-secondary">Apps</h2>
      <div class="list-actions">
        <a class="button-primary" href="#">ProtoYi</a>
        <a class="button-primary" href="#">PorchWise</a>
        <a class="button-primary" href="#">Blame Game</a>
        <a class="button-primary" href="#">Rezonate</a>
        <a class="button-primary" href="#">Build-a-Mind</a>
      </div>
      <p class="typography-secondary">Stubs only. Link real apps when available.</p>
    </div>

    <hr class="divider" />

    <div class="section">
      <h2 class="heading-secondary">Hydi Autopilot</h2>
      <p class="typography-secondary">
        Local desktop agent required for USB keyboard/mouse control. This web app
        provides orchestration and configuration only.
      </p>
      <div class="list-actions">
        <button class="button-secondary" type="button" id="btn-autopilot">Enable Autopilot (stub)</button>
      </div>
      <script>
        const btn = document.getElementById('btn-autopilot');
        btn?.addEventListener('click', () => {
          alert('Autopilot requires a local agent. Not enabled in web.');
        });
      </script>
    </div>
  </main>
</Layout>
